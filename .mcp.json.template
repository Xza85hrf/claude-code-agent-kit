{
  "_readme": {
    "description": "MCP Server Configuration Template",
    "architecture": "On-demand loading to optimize context tokens (~25K base)",
    "tiers": {
      "1": "ESSENTIAL - memory, context7, sequential-thinking",
      "2": "OLLAMA - Local/cloud AI workers",
      "3": "EXTERNAL AI - DeepSeek reasoning",
      "4": "DEV TOOLS - GitHub operations",
      "5": "CLOUD SERVICES - Vercel, Cloudflare",
      "6": "AUTOMATION - n8n workflows"
    },
    "see_also": "MCP-CATALOG.md for service MCPs (Notion, Sentry, Figma, etc.)"
  },
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "description": "[Tier 1] Persistent memory across sessions"
    },

    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp-server"],
      "description": "[Tier 1] Live documentation lookup for any library"
    },

    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "description": "[Tier 1] Chain-of-thought reasoning for complex problems"
    },

    "ollama": {
      "command": "npx",
      "args": ["-y", "ollama-mcp"],
      "env": {
        "OLLAMA_HOST": "${OLLAMA_HOST:-http://localhost:11434}"
      },
      "description": "[Tier 2] Full Ollama SDK - model management, generation, chat, embeddings"
    },

    "ollama-delegate": {
      "command": "node",
      "args": ["${HOME}/.claude/mcp-servers/ollama-claude/index.js"],
      "env": {
        "OLLAMA_HOST": "${OLLAMA_HOST:-http://localhost:11434}",
        "DEFAULT_MODEL": "${OLLAMA_DEFAULT_MODEL:-kimi-k2.5:cloud}",
        "FALLBACK_MODEL": "${OLLAMA_FALLBACK_MODEL:-glm-4.7-flash}"
      },
      "description": "[Tier 2] Delegate coding tasks to local Ollama (98% token reduction)"
    },

    "deepseek": {
      "command": "npx",
      "args": ["-y", "deepseek-mcp-server"],
      "env": {
        "DEEPSEEK_API_KEY": "${DEEPSEEK_API_KEY}"
      },
      "description": "[Tier 3] DeepSeek R1 reasoning + V3 chat - great for complex analysis"
    },

    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "[Tier 4] GitHub operations - PRs, issues, repos"
    },

    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com",
      "description": "[Tier 5] Vercel deployments (requires Vercel CLI auth)"
    },

    "cloudflare-docs": {
      "type": "http",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "description": "[Tier 5] Cloudflare documentation search"
    },

    "n8n": {
      "type": "http",
      "url": "http://localhost:5678/mcp-server/http",
      "headers": {
        "authorization": "Bearer ${N8N_MCP_TOKEN}"
      },
      "description": "[Tier 6] n8n workflow automation (requires local n8n)"
    }
  },

  "disabledMcpServers": [
    "ollama-delegate",
    "vercel",
    "cloudflare-docs",
    "n8n"
  ],

  "_setup": {
    "quick_start": [
      "1. Copy to .mcp.json in project root",
      "2. Run: source setup-env.sh (or add to ~/.bashrc)",
      "3. Core MCPs (context7, github) work out of the box",
      "4. For service MCPs (Sentry, Notion, etc.), see MCP-CATALOG.md",
      "5. Enable on-demand MCPs via .claude/settings.local.json",
      "6. Restart Claude Code after changes"
    ],
    "ollama_models_recommended": {
      "coding": "kimi-k2.5:cloud (tools+thinking) or glm-4.7-flash (fast)",
      "vision": "qwen3-vl:32b (high quality) or qwen3-vl:8b (faster)",
      "agentic_swe": "devstral-small-2 (SWE-bench 65.8%, tools+vision, 384K ctx)",
      "code_reasoning": "deepcoder (o3-mini level, HumanEval+ 92.6%)",
      "reasoning": "Use DeepSeek R1 via deepseek MCP"
    },
    "advanced_servers": {
      "claude-context": {
        "command": "npx",
        "args": ["-y", "@zilliz/claude-context-mcp@latest"],
        "env": {
          "OPENAI_API_KEY": "${OPENAI_API_KEY}",
          "MILVUS_TOKEN": "${MILVUS_TOKEN}"
        },
        "description": "Semantic codebase search - 40% token reduction"
      },
      "pal": {
        "command": "uvx",
        "args": ["--from", "pal-mcp-server", "pal-server"],
        "env": {
          "GEMINI_API_KEY": "${GEMINI_API_KEY}",
          "OPENAI_API_KEY": "${OPENAI_API_KEY}",
          "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
        },
        "description": "Multi-model orchestration (Gemini, GPT, O3, etc.)"
      },
      "firecrawl": {
        "command": "npx",
        "args": ["-y", "firecrawl-mcp"],
        "env": {
          "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
        },
        "description": "Web scraping and crawling"
      },
      "supabase": {
        "command": "npx",
        "args": ["-y", "@supabase/mcp-server-supabase@latest", "--project-ref=${SUPABASE_PROJECT_REF}"],
        "description": "Supabase database operations"
      }
    }
  }
}
